@using Microsoft.AspNetCore.Components.Authorization
@using CapheVanPhong.Application.Services
@using Microsoft.Extensions.DependencyInjection

@inject IServiceScopeFactory ScopeFactory

<div class="container-fluid p-0 nav-bar">
    <nav class="navbar navbar-expand-lg bg-none navbar-dark py-3">
        <a href="/" class="navbar-brand px-lg-4 m-0">
            <h1 class="m-0 display-4 text-uppercase text-white">Cà Phê Văn Phòng</h1>
        </a>
        <button type="button" class="navbar-toggler" data-toggle="collapse" data-target="#navbarCollapse">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse justify-content-between" id="navbarCollapse">
            <div class="navbar-nav ml-auto p-4">
                <NavLink href="/" class="nav-item nav-link" ActiveClass="active" Match="NavLinkMatch.All">Trang Chủ</NavLink>
                <NavLink href="/gioi-thieu" class="nav-item nav-link" ActiveClass="active">Giới Thiệu</NavLink>
                <div class="nav-item dropdown">
                    <a href="/dich-vu" class="nav-link dropdown-toggle" data-toggle="dropdown">Dịch Vụ</a>
                    <div class="dropdown-menu text-capitalize">
                        @foreach (var svc in _commercialServices)
                        {
                            <NavLink href="@($"/dich-vu/{svc.Slug}")" class="dropdown-item" ActiveClass="active">@svc.Title</NavLink>
                        }
                        @if (!_commercialServices.Any())
                        {
                            <span class="dropdown-item text-muted disabled">Sắp có...</span>
                        }
                    </div>
                </div>
                <NavLink href="/thuc-don" class="nav-item nav-link" ActiveClass="active">Thực Đơn</NavLink>
                <div class="nav-item dropdown">
                    <a href="#" class="nav-link dropdown-toggle" data-toggle="dropdown">Trang Khác</a>
                    <div class="dropdown-menu text-capitalize">
                        <NavLink href="/dat-ban" class="dropdown-item" ActiveClass="active">Đặt Bàn</NavLink>
                        <NavLink href="/danh-gia" class="dropdown-item" ActiveClass="active">Đánh Giá</NavLink>
                        <NavLink href="/tin-hot" class="dropdown-item" ActiveClass="active">Tin Hot</NavLink>
                    </div>
                </div>
                <div class="nav-item dropdown">
                    <a href="#" class="nav-link dropdown-toggle" data-toggle="dropdown">Tin Tức</a>
                    <div class="dropdown-menu text-capitalize">
                        @foreach (var cat in _blogCategories)
                        {
                            <NavLink href="@($"/tin-tuc/{cat.Slug}")" class="dropdown-item" ActiveClass="active">@cat.Name</NavLink>
                        }
                        @if (!_blogCategories.Any())
                        {
                            <span class="dropdown-item text-muted disabled">Sắp có...</span>
                        }
                    </div>
                </div>
                <NavLink href="/lien-he" class="nav-item nav-link" ActiveClass="active">Liên Hệ</NavLink>

                <AuthorizeView>
                    <Authorized>
                        <div class="nav-item dropdown">
                            <a href="#" class="nav-link dropdown-toggle" data-toggle="dropdown">
                                <i class="fa fa-user mr-1"></i>@context.User.Identity?.Name
                            </a>
                            <div class="dropdown-menu text-capitalize">
                                <AuthorizeView Roles="Admin, SuperAdmin">
                                    <Authorized Context="adminCtx">
                                        <a href="#" class="dropdown-item" onclick="window.location='/admin'; return false;">Quản Trị</a>
                                    </Authorized>
                                </AuthorizeView>
                                <a href="/don-hang-cua-toi" class="dropdown-item">Đơn Hàng Của Tôi</a>
                                <a href="/account/logout" class="dropdown-item">Đăng Xuất</a>
                            </div>
                        </div>
                    </Authorized>
                    <NotAuthorized>
                        <NavLink href="/account/login" class="nav-item nav-link" ActiveClass="active">Đăng Nhập</NavLink>
                        <NavLink href="/account/register" class="nav-item nav-link btn btn-primary ml-2 px-3" ActiveClass="active">Đăng Ký</NavLink>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </div>
    </nav>
</div>

@code {
    private List<CapheVanPhong.Domain.Entities.BlogCategory> _blogCategories = [];
    private List<CapheVanPhong.Domain.Entities.CommercialService> _commercialServices = [];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await using var scope = ScopeFactory.CreateAsyncScope();
            var blogCategoryService = scope.ServiceProvider.GetRequiredService<IBlogCategoryService>();
            _blogCategories = (await blogCategoryService.GetActiveAsync())
                .OrderBy(c => c.DisplayOrder)
                .ThenBy(c => c.Name)
                .ToList();
        }
        catch { /* ignore on prerender */ }

        try
        {
            await using var scope = ScopeFactory.CreateAsyncScope();
            var commercialServiceService = scope.ServiceProvider.GetRequiredService<ICommercialServiceService>();
            _commercialServices = (await commercialServiceService.GetActiveAsync())
                .ToList();
        }
        catch { /* ignore on prerender */ }
    }
}
