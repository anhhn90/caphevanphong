@page "/lien-he"
@layout Layout
@using CapheVanPhong.Web.Components.Layout
@using Microsoft.AspNetCore.Components.Forms
@inherits ContactBase

<PageTitle>Liên Hệ - Cà Phê Văn Phòng</PageTitle>

<!-- Page Header Start -->
<div class="container-fluid page-header mb-5 position-relative overlay-bottom">
    <div class="d-flex flex-column align-items-center justify-content-center pt-0 pt-lg-5" style="min-height: 400px">
        <h1 class="display-4 mb-3 mt-0 mt-lg-5 text-white text-uppercase">Liên Hệ</h1>
        <div class="d-inline-flex mb-lg-5">
            <p class="m-0 text-white"><a class="text-white" href="/">Trang Chủ</a></p>
            <p class="m-0 text-white px-2">/</p>
            <p class="m-0 text-white">Liên Hệ</p>
        </div>
    </div>
</div>
<!-- Page Header End -->

<!-- Contact Start -->
<div class="container-fluid pt-5">
    <div class="container">
        <div class="section-title">
            <h4 class="text-primary text-uppercase" style="letter-spacing: 5px;">Liên Hệ Với Chúng Tôi</h4>
            <h1 class="display-4">Hãy Kết Nối Với Chúng Tôi</h1>
        </div>
        <div class="row px-3 pb-2">
            <div class="col-sm-4 text-center mb-3">
                <i class="fa fa-2x fa-map-marker-alt mb-3 text-primary"></i>
                <h4 class="font-weight-bold">Địa Chỉ</h4>
                <p>123 Đường Lê Lợi, Quận 1, TP. Hồ Chí Minh</p>
            </div>
            <div class="col-sm-4 text-center mb-3">
                <i class="fa fa-2x fa-phone-alt mb-3 text-primary"></i>
                <h4 class="font-weight-bold">Điện Thoại</h4>
                <p>+84 012 345 6789</p>
            </div>
            <div class="col-sm-4 text-center mb-3">
                <i class="far fa-2x fa-envelope mb-3 text-primary"></i>
                <h4 class="font-weight-bold">Email</h4>
                <p>info@caphevanphong.vn</p>
            </div>
        </div>
        <div class="row">
            <div class="col-md-6 pb-5">
                <iframe style="width: 100%; height: 443px; border: 0;"
                        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3919.4355!2d106.6913!3d10.7769!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMTDCsDQ2JzM2LjgiTiAxMDbCsDQxJzI4LjciRQ!5e0!3m2!1sen!2svn!4v1603794290143!5m2!1sen!2svn"
                        frameborder="0" allowfullscreen="" aria-hidden="false" tabindex="0"
                        title="Bản đồ Cà Phê Văn Phòng"></iframe>
            </div>
            <div class="col-md-6 pb-5">
                <div class="contact-form">
                    @if (IsMessageSent)
                    {
                        <div class="alert alert-success">
                            <i class="fa fa-check-circle mr-2"></i>
                            Cảm ơn bạn đã liên hệ! Chúng tôi sẽ phản hồi trong vòng 24 giờ.
                        </div>
                    }
                    else
                    {
                        <EditForm Model="ContactModel" OnValidSubmit="HandleContactSubmit">
                            <DataAnnotationsValidator />

                            <div class="control-group mb-3">
                                <InputText @bind-Value="ContactModel.Name"
                                           class="form-control bg-transparent p-4"
                                           placeholder="Họ và tên của bạn" />
                                <ValidationMessage For="() => ContactModel.Name" class="text-danger small" />
                            </div>
                            <div class="control-group mb-3">
                                <InputText @bind-Value="ContactModel.Email"
                                           class="form-control bg-transparent p-4"
                                           placeholder="Địa chỉ email" />
                                <ValidationMessage For="() => ContactModel.Email" class="text-danger small" />
                            </div>
                            <div class="control-group mb-3">
                                <InputText @bind-Value="ContactModel.Subject"
                                           class="form-control bg-transparent p-4"
                                           placeholder="Tiêu đề" />
                                <ValidationMessage For="() => ContactModel.Subject" class="text-danger small" />
                            </div>
                            <div class="control-group mb-3">
                                <InputTextArea @bind-Value="ContactModel.Message"
                                               class="form-control bg-transparent py-3 px-4"
                                               rows="5"
                                               placeholder="Nội dung tin nhắn" />
                                <ValidationMessage For="() => ContactModel.Message" class="text-danger small" />
                            </div>

                            @if (!string.IsNullOrEmpty(ErrorMessage))
                            {
                                <div class="alert alert-danger mb-3">@ErrorMessage</div>
                            }

                            <div>
                                <button class="btn btn-primary font-weight-bold py-3 px-5"
                                        type="submit"
                                        disabled="@IsSubmitting">
                                    @if (IsSubmitting)
                                    {
                                        <span class="spinner-border spinner-border-sm mr-2" role="status"></span>
                                        <span>Đang gửi...</span>
                                    }
                                    else
                                    {
                                        <span>Gửi Tin Nhắn</span>
                                    }
                                </button>
                            </div>
                        </EditForm>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Contact End -->
