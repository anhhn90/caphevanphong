@page "/"
@layout Layout
@using CapheVanPhong.Web.Components.Layout
@inherits HomeBase

<PageTitle>Trang Chủ - Cà Phê Văn Phòng</PageTitle>

<!-- Carousel Start -->
<div class="container-fluid p-0 mb-5">
    <div id="blog-carousel" class="carousel slide overlay-bottom" data-ride="carousel">
        <div class="carousel-inner">
            <div class="carousel-item active">
                <img class="w-100" src="public/img/carousel-1.jpg" alt="Ảnh cà phê 1">
                <div class="carousel-caption d-flex flex-column align-items-center justify-content-center">
                    <h2 class="text-primary font-weight-medium m-0">Chúng Tôi Đã Phục Vụ</h2>
                    <h1 class="display-1 text-white m-0">CÀ PHÊ</h1>
                    <h2 class="text-white m-0">* TỪ NĂM 2010 *</h2>
                </div>
            </div>
            <div class="carousel-item">
                <img class="w-100" src="public/img/carousel-2.jpg" alt="Ảnh cà phê 2">
                <div class="carousel-caption d-flex flex-column align-items-center justify-content-center">
                    <h2 class="text-primary font-weight-medium m-0">Hương Vị Đặc Biệt</h2>
                    <h1 class="display-1 text-white m-0">CÀ PHÊ</h1>
                    <h2 class="text-white m-0">* NGUYÊN CHẤT 100% *</h2>
                </div>
            </div>
        </div>
        <a class="carousel-control-prev" href="#blog-carousel" data-slide="prev">
            <span class="carousel-control-prev-icon"></span>
        </a>
        <a class="carousel-control-next" href="#blog-carousel" data-slide="next">
            <span class="carousel-control-next-icon"></span>
        </a>
    </div>
</div>
<!-- Carousel End -->

<!-- About Start -->
<div class="container-fluid py-5">
    <div class="container">
        <div class="section-title">
            <h4 class="text-primary text-uppercase" style="letter-spacing: 5px;">Về Chúng Tôi</h4>
            <h1 class="display-4">Phục Vụ Từ Năm 2010</h1>
        </div>
        <div class="row">
            <div class="col-lg-4 py-0 py-lg-5">
                <h1 class="mb-3">Câu Chuyện Của Chúng Tôi</h1>
                <h5 class="mb-3">Cà Phê Văn Phòng — nơi bạn tìm thấy sự bình yên trong từng tách cà phê.</h5>
                <p>Được thành lập từ năm 2010, Cà Phê Văn Phòng ra đời với tâm huyết mang đến cho khách hàng những tách cà phê nguyên chất, được chọn lọc kỹ càng từ những vùng trồng cà phê nổi tiếng của Việt Nam.</p>
                <a href="/gioi-thieu" class="btn btn-secondary font-weight-bold py-2 px-4 mt-2">Tìm Hiểu Thêm</a>
            </div>
            <div class="col-lg-4 py-5 py-lg-0" style="min-height: 500px;">
                <div class="position-relative h-100">
                    <img class="position-absolute w-100 h-100" src="public/img/about.png" style="object-fit: cover;" alt="Về chúng tôi">
                </div>
            </div>
            <div class="col-lg-4 py-0 py-lg-5">
                <h1 class="mb-3">Tầm Nhìn Của Chúng Tôi</h1>
                <p>Chúng tôi mong muốn trở thành điểm đến quen thuộc của mọi người, nơi mà mỗi buổi sáng bạn có thể bắt đầu ngày mới với một tách cà phê thơm ngon và không gian ấm cúng.</p>
                <h5 class="mb-3"><i class="fa fa-check text-primary mr-3"></i>Cà phê nguyên chất 100%</h5>
                <h5 class="mb-3"><i class="fa fa-check text-primary mr-3"></i>Không gian thoải mái, yên tĩnh</h5>
                <h5 class="mb-3"><i class="fa fa-check text-primary mr-3"></i>Phục vụ tận tâm, chuyên nghiệp</h5>
                <a href="/gioi-thieu" class="btn btn-primary font-weight-bold py-2 px-4 mt-2">Tìm Hiểu Thêm</a>
            </div>
        </div>
    </div>
</div>
<!-- About End -->

<!-- Service Start -->
<div class="container-fluid pt-5">
    <div class="container">
        <div class="section-title">
            <h4 class="text-primary text-uppercase" style="letter-spacing: 5px;">Dịch Vụ Của Chúng Tôi</h4>
            <h1 class="display-4">Hạt Cà Phê Tươi & Hữu Cơ</h1>
        </div>
        <div class="row">
            <div class="col-lg-6 mb-5">
                <div class="row align-items-center">
                    <div class="col-sm-5">
                        <img class="img-fluid mb-3 mb-sm-0" src="public/img/service-1.jpg" alt="Giao hàng tận nơi">
                    </div>
                    <div class="col-sm-7">
                        <h4><i class="fa fa-truck service-icon"></i>Giao Hàng Tận Nơi</h4>
                        <p class="m-0">Dịch vụ giao cà phê tận nhà nhanh chóng, đảm bảo cà phê luôn nóng hổi khi đến tay bạn.</p>
                    </div>
                </div>
            </div>
            <div class="col-lg-6 mb-5">
                <div class="row align-items-center">
                    <div class="col-sm-5">
                        <img class="img-fluid mb-3 mb-sm-0" src="public/img/service-2.jpg" alt="Hạt cà phê tươi">
                    </div>
                    <div class="col-sm-7">
                        <h4><i class="fa fa-coffee service-icon"></i>Hạt Cà Phê Tươi</h4>
                        <p class="m-0">Hạt cà phê được tuyển chọn từ các vùng trồng nổi tiếng Tây Nguyên, rang xay tươi mỗi ngày.</p>
                    </div>
                </div>
            </div>
            <div class="col-lg-6 mb-5">
                <div class="row align-items-center">
                    <div class="col-sm-5">
                        <img class="img-fluid mb-3 mb-sm-0" src="public/img/service-3.jpg" alt="Chất lượng hàng đầu">
                    </div>
                    <div class="col-sm-7">
                        <h4><i class="fa fa-award service-icon"></i>Chất Lượng Hàng Đầu</h4>
                        <p class="m-0">Mỗi tách cà phê đều được kiểm soát chất lượng nghiêm ngặt để đảm bảo hương vị tốt nhất.</p>
                    </div>
                </div>
            </div>
            <div class="col-lg-6 mb-5">
                <div class="row align-items-center">
                    <div class="col-sm-5">
                        <img class="img-fluid mb-3 mb-sm-0" src="public/img/service-4.jpg" alt="Đặt bàn trực tuyến">
                    </div>
                    <div class="col-sm-7">
                        <h4><i class="fa fa-table service-icon"></i>Đặt Bàn Trực Tuyến</h4>
                        <p class="m-0">Đặt bàn trực tuyến dễ dàng và nhận ngay ưu đãi 30% cho lần đặt bàn đầu tiên.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Service End -->

<!-- Offer Start -->
<div class="offer container-fluid my-5 py-5 text-center position-relative overlay-top overlay-bottom">
    <div class="container py-5">
        <h1 class="display-3 text-primary mt-3">GIẢM 50%</h1>
        <h1 class="text-white mb-3">Ưu Đãi Đặc Biệt Chủ Nhật</h1>
        <h4 class="text-white font-weight-normal mb-4 pb-3">Chỉ áp dụng vào Chủ Nhật từ 01/01 đến 30/01/2025</h4>
        <form class="form-inline justify-content-center mb-4">
            <div class="input-group">
                <input type="text" class="form-control p-4" placeholder="Email của bạn" style="height: 60px;">
                <div class="input-group-append">
                    <button class="btn btn-primary font-weight-bold px-4" type="submit">Đăng Ký</button>
                </div>
            </div>
        </form>
    </div>
</div>
<!-- Offer End -->

<!-- Menu Preview Start -->
<div class="container-fluid pt-5">
    <div class="container">
        <div class="section-title">
            <h4 class="text-primary text-uppercase" style="letter-spacing: 5px;">Thực Đơn & Giá Cả</h4>
            <h1 class="display-4">Giá Cả Cạnh Tranh</h1>
        </div>
        <div class="row">
            <div class="col-lg-6">
                <h1 class="mb-5">Cà Phê Nóng</h1>
                @foreach (var item in HotCoffeeItems)
                {
                    <div class="row align-items-center mb-5">
                        <div class="col-4 col-sm-3">
                            <img class="w-100 rounded-circle mb-3 mb-sm-0" src="@item.ImageUrl" alt="@item.Name">
                            <h5 class="menu-price">@item.Price.ToString("N0")đ</h5>
                        </div>
                        <div class="col-8 col-sm-9">
                            <h4>@item.Name</h4>
                            <p class="m-0">@item.Description</p>
                        </div>
                    </div>
                }
            </div>
            <div class="col-lg-6">
                <h1 class="mb-5">Cà Phê Đá</h1>
                @foreach (var item in ColdCoffeeItems)
                {
                    <div class="row align-items-center mb-5">
                        <div class="col-4 col-sm-3">
                            <img class="w-100 rounded-circle mb-3 mb-sm-0" src="@item.ImageUrl" alt="@item.Name">
                            <h5 class="menu-price">@item.Price.ToString("N0")đ</h5>
                        </div>
                        <div class="col-8 col-sm-9">
                            <h4>@item.Name</h4>
                            <p class="m-0">@item.Description</p>
                        </div>
                    </div>
                }
            </div>
        </div>
        <div class="text-center mb-5">
            <a href="/thuc-don" class="btn btn-primary font-weight-bold py-3 px-5">Xem Thực Đơn Đầy Đủ</a>
        </div>
    </div>
</div>
<!-- Menu Preview End -->

<!-- Reservation Start -->
<div class="container-fluid my-5">
    <div class="container">
        <div class="reservation position-relative overlay-top overlay-bottom">
            <div class="row align-items-center">
                <div class="col-lg-6 my-5 my-lg-0">
                    <div class="p-5">
                        <div class="mb-4">
                            <h1 class="display-3 text-primary">GIẢM 30%</h1>
                            <h1 class="text-white">Khi Đặt Bàn Trực Tuyến</h1>
                        </div>
                        <p class="text-white">Đặt bàn trực tuyến ngay hôm nay để nhận ưu đãi đặc biệt. Chúng tôi đảm bảo bạn sẽ có một trải nghiệm tuyệt vời tại Cà Phê Văn Phòng.</p>
                        <ul class="list-inline text-white m-0">
                            <li class="py-2"><i class="fa fa-check text-primary mr-3"></i>Giảm 30% tổng hóa đơn</li>
                            <li class="py-2"><i class="fa fa-check text-primary mr-3"></i>Ưu tiên chỗ ngồi đẹp</li>
                            <li class="py-2"><i class="fa fa-check text-primary mr-3"></i>Phục vụ tận tình</li>
                        </ul>
                    </div>
                </div>
                <div class="col-lg-6">
                    <div class="text-center p-5" style="background: rgba(51, 33, 29, .8);">
                        <h1 class="text-white mb-4 mt-5">Đặt Bàn Của Bạn</h1>
                        <p class="text-white mb-4">Để đặt bàn trực tuyến và nhận ưu đãi, vui lòng truy cập trang đặt bàn.</p>
                        <a href="/dat-ban" class="btn btn-primary btn-block font-weight-bold py-3">Đặt Bàn Ngay</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Reservation End -->

<!-- Testimonial Start -->
<div class="container-fluid py-5">
    <div class="container">
        <div class="section-title">
            <h4 class="text-primary text-uppercase" style="letter-spacing: 5px;">Đánh Giá</h4>
            <h1 class="display-4">Khách Hàng Nói Gì</h1>
        </div>
        <div class="owl-carousel testimonial-carousel">
            @foreach (var testimonial in Testimonials)
            {
                <div class="testimonial-item">
                    <div class="d-flex align-items-center mb-3">
                        <img class="img-fluid" src="@testimonial.ImageUrl" alt="@testimonial.Name">
                        <div class="ml-3">
                            <h4>@testimonial.Name</h4>
                            <i>@testimonial.Profession</i>
                        </div>
                    </div>
                    <p class="m-0">@testimonial.Content</p>
                </div>
            }
        </div>
    </div>
</div>
<!-- Testimonial End -->

@if (ActiveHotNews.Count > 0)
{
    <script id="hot-news-data" type="application/json">@((MarkupString)System.Text.Json.JsonSerializer.Serialize(
        ActiveHotNews.Select(n => new { id = n.Id, title = n.Title, content = n.Content, imageUrl = n.ImageUrl })
    ))</script>
}

<!-- Hot News Modal (Bootstrap 4) -->
<div class="modal fade" id="hotNewsModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title font-weight-bold" id="hotNewsTitle"></h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Đóng">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body pt-2">
                <img id="hotNewsImage" src="" alt="" class="img-fluid rounded mb-3 d-none"
                     style="max-height:300px; width:100%; object-fit:cover;" />
                <div id="hotNewsContent"></div>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-outline-secondary btn-sm" id="hotNewsDismiss">
                    Không nhắc lại trong 3 ngày
                </button>
                <button type="button" class="btn btn-primary" data-dismiss="modal">Đóng</button>
            </div>
        </div>
    </div>
</div>
