@page "/dich-vu/{Slug}"
@layout Layout
@using CapheVanPhong.Application.Services
@using CapheVanPhong.Web.Components.Layout

@inject ICommercialServiceService CommercialServiceService

<PageTitle>@(_service?.Title ?? "Dịch Vụ") - Cà Phê Văn Phòng</PageTitle>

<!-- Page Header -->
<div class="container-fluid page-header mb-5 p-0"
     style="background: linear-gradient(rgba(45,45,45,.7),rgba(45,45,45,.7)), url('/public/img/carousel-1.jpg') center center; background-size: cover;">
    <div class="container-fluid page-header-inner py-5">
        <div class="container text-center">
            <h1 class="display-3 text-white mb-3 animated slideInDown">
                @(_service?.Title ?? "Dịch Vụ")
            </h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb justify-content-center text-uppercase">
                    <li class="breadcrumb-item"><a href="/" class="text-white">Trang Chủ</a></li>
                    <li class="breadcrumb-item"><a href="/dich-vu" class="text-white">Dịch Vụ</a></li>
                    <li class="breadcrumb-item text-white active" aria-current="page">Chi Tiết</li>
                </ol>
            </nav>
        </div>
    </div>
</div>

<!-- Service Detail -->
<div class="container-fluid py-5">
    <div class="container">

        @if (_isLoading)
        {
            <div class="text-center py-5">
                <p class="text-muted">Đang tải...</p>
            </div>
        }
        else if (_notFound || _service is null)
        {
            <div class="text-center py-5">
                <i class="fa fa-exclamation-circle fa-3x text-muted mb-3 d-block"></i>
                <p class="text-muted">Không tìm thấy dịch vụ này.</p>
                <a href="/dich-vu" class="btn btn-primary mt-2">← Quay Lại Dịch Vụ</a>
            </div>
        }
        else
        {
            <div class="row justify-content-center">
                <div class="col-lg-9">

                    <!-- Icon & Title -->
                    <div class="d-flex align-items-center mb-4">
                        <i class="@_service.IconClass fa-2x text-primary mr-3"></i>
                        <h2 class="mb-0">@_service.Title</h2>
                    </div>

                    <!-- Featured Image -->
                    @if (!string.IsNullOrEmpty(_service.ImageName))
                    {
                        <div class="mb-4">
                            <img src="/public/img/commercial-services/@_service.ImageName" alt="@_service.Title"
                                 class="img-fluid rounded shadow-sm w-100"
                                 style="max-height:450px; object-fit:cover;" />
                        </div>
                    }

                    <!-- Introduction -->
                    <div class="service-introduction mb-4" style="line-height:1.9; font-size:1.05rem;">
                        @((MarkupString)_service.Introduction)
                    </div>

                    <!-- Full Content -->
                    @if (!string.IsNullOrEmpty(_service.Content))
                    {
                        <div class="service-content" style="line-height:1.9; font-size:1.05rem;">
                            @((MarkupString)_service.Content)
                        </div>
                    }

                    <!-- Back link -->
                    <div class="mt-5 pt-4" style="border-top:1px solid #eee;">
                        <a href="/dich-vu" class="btn btn-outline-primary">
                            <i class="fa fa-arrow-left mr-1"></i> Quay Lại Dịch Vụ
                        </a>
                    </div>

                </div>
            </div>
        }

    </div>
</div>

@code {
    [Parameter] public string Slug { get; set; } = string.Empty;

    private CapheVanPhong.Domain.Entities.CommercialService? _service;
    private bool _isLoading = true;
    private bool _notFound;

    protected override async Task OnInitializedAsync()
    {
        _service = await CommercialServiceService.GetBySlugAsync(Slug);

        if (_service is null || !_service.IsActive)
        {
            _notFound = true;
        }

        _isLoading = false;
    }
}
