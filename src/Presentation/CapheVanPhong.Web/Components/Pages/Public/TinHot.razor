@page "/tin-hot"
@layout Layout
@using CapheVanPhong.Application.Services
@using CapheVanPhong.Web.Components.Layout

@inject IHotNewsService HotNewsService

<PageTitle>Tin Hot - Cà Phê Văn Phòng</PageTitle>

<!-- Page Header -->
<div class="container-fluid page-header mb-5 p-0" style="background: linear-gradient(rgba(45,45,45,.7),rgba(45,45,45,.7)), url('/public/img/carousel-1.jpg') center center; background-size: cover;">
    <div class="container-fluid page-header-inner py-5">
        <div class="container text-center">
            <h1 class="display-3 text-white mb-3 animated slideInDown">Tin Hot</h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb justify-content-center text-uppercase">
                    <li class="breadcrumb-item"><a href="/" class="text-white">Trang Chủ</a></li>
                    <li class="breadcrumb-item text-white active" aria-current="page">Tin Hot</li>
                </ol>
            </nav>
        </div>
    </div>
</div>

<!-- Hot News List -->
<div class="container-fluid py-5">
    <div class="container">

        <div class="section-title text-center mb-5">
            <h4 class="text-primary text-uppercase" style="letter-spacing:5px;">Cập Nhật Mới Nhất</h4>
            <h1 class="display-4">Tin Tức Nổi Bật</h1>
        </div>

        @if (_isLoading)
        {
            <div class="text-center py-5">
                <p class="text-muted">Đang tải...</p>
            </div>
        }
        else if (_items.Count == 0)
        {
            <div class="text-center py-5">
                <i class="fa fa-newspaper-o fa-3x text-muted mb-3 d-block"></i>
                <p class="text-muted">Hiện chưa có tin hot nào.</p>
            </div>
        }
        else
        {
            <div class="row">
                @foreach (var item in _items)
                {
                    <div class="col-lg-6 mb-5">
                        <div class="card h-100 border-0 shadow-sm" style="border-radius:8px; overflow:hidden;">
                            @if (!string.IsNullOrEmpty(item.ImageName))
                            {
                                <img src="/public/img/hotnews/@item.ImageName" alt="@item.Title"
                                     class="card-img-top" style="height:220px; object-fit:cover;" />
                            }
                            <div class="card-body p-4">
                                <p class="text-muted small mb-2">
                                    <i class="fa fa-clock-o mr-1"></i>
                                    @item.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                                </p>
                                <h4 class="card-title mb-3">@item.Title</h4>
                                <div class="card-text hot-news-content">@((MarkupString)item.Content)</div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }

    </div>
</div>

@code {
    private List<CapheVanPhong.Domain.Entities.HotNews> _items = [];
    private bool _isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        _items = (await HotNewsService.GetActiveAsync()).ToList();
        _isLoading = false;
    }
}
