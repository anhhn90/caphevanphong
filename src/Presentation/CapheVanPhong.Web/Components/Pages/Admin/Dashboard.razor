@page "/admin"
@page "/admin/dashboard"
@layout AdminLayout
@attribute [Authorize(Roles = "Admin, SuperAdmin")]
@using CapheVanPhong.Web.Components.Layout
@using Microsoft.AspNetCore.Authorization

<PageTitle>Dashboard - Admin</PageTitle>

<!-- Page Heading -->
<div class="page-head">
    <h2 class="pull-left"><i class="fa fa-home"></i> Dashboard</h2>
    <div class="bread-crumb pull-right">
        <a href="/admin"><i class="fa fa-home"></i> Home</a>
        <span class="divider">/</span>
        <a href="#" class="bread-current">Dashboard</a>
    </div>
    <div class="clearfix"></div>
</div>

<!-- Matter -->
<div class="matter">
    <div class="container">

        <!-- Quick Stats Row -->
        <div class="row">

            <div class="col-md-3 col-sm-6">
                <div class="widget wblue">
                    <div class="widget-head">
                        <div class="pull-left">Total Orders</div>
                        <div class="widget-icons pull-right">
                            <a href="/admin/orders"><i class="fa fa-arrow-right"></i></a>
                        </div>
                        <div class="clearfix"></div>
                    </div>
                    <div class="widget-content">
                        <div class="padd">
                            <h2 class="text-center"><i class="fa fa-shopping-cart"></i></h2>
                            <h3 class="text-center">—</h3>
                            <p class="text-center text-muted">All time orders</p>
                        </div>
                    </div>
                    <div class="widget-foot">
                        <a href="/admin/orders">View all orders <i class="fa fa-arrow-right"></i></a>
                    </div>
                </div>
            </div>

            <div class="col-md-3 col-sm-6">
                <div class="widget worange">
                    <div class="widget-head">
                        <div class="pull-left">Pending Orders</div>
                        <div class="widget-icons pull-right">
                            <a href="/admin/orders/pending"><i class="fa fa-arrow-right"></i></a>
                        </div>
                        <div class="clearfix"></div>
                    </div>
                    <div class="widget-content">
                        <div class="padd">
                            <h2 class="text-center"><i class="fa fa-clock-o"></i></h2>
                            <h3 class="text-center">—</h3>
                            <p class="text-center text-muted">Awaiting confirmation</p>
                        </div>
                    </div>
                    <div class="widget-foot">
                        <a href="/admin/orders/pending">View pending <i class="fa fa-arrow-right"></i></a>
                    </div>
                </div>
            </div>

            <div class="col-md-3 col-sm-6">
                <div class="widget wgreen">
                    <div class="widget-head">
                        <div class="pull-left">Products</div>
                        <div class="widget-icons pull-right">
                            <a href="/admin/products"><i class="fa fa-arrow-right"></i></a>
                        </div>
                        <div class="clearfix"></div>
                    </div>
                    <div class="widget-content">
                        <div class="padd">
                            <h2 class="text-center"><i class="fa fa-list"></i></h2>
                            <h3 class="text-center">—</h3>
                            <p class="text-center text-muted">Menu items</p>
                        </div>
                    </div>
                    <div class="widget-foot">
                        <a href="/admin/products">Manage menu <i class="fa fa-arrow-right"></i></a>
                    </div>
                </div>
            </div>

            <div class="col-md-3 col-sm-6">
                <div class="widget wred">
                    <div class="widget-head">
                        <div class="pull-left">Users</div>
                        <div class="widget-icons pull-right">
                            <a href="/admin/users"><i class="fa fa-arrow-right"></i></a>
                        </div>
                        <div class="clearfix"></div>
                    </div>
                    <div class="widget-content">
                        <div class="padd">
                            <h2 class="text-center"><i class="fa fa-users"></i></h2>
                            <h3 class="text-center">—</h3>
                            <p class="text-center text-muted">Registered customers</p>
                        </div>
                    </div>
                    <div class="widget-foot">
                        <a href="/admin/users">Manage users <i class="fa fa-arrow-right"></i></a>
                    </div>
                </div>
            </div>

        </div>
        <!-- Quick Stats Row End -->

        <!-- Quick Actions Row -->
        <div class="row">

            <div class="col-md-6">
                <div class="widget">
                    <div class="widget-head">
                        <div class="pull-left">Quick Actions</div>
                        <div class="clearfix"></div>
                    </div>
                    <div class="widget-content">
                        <div class="padd">
                            <p><a href="/admin/orders" class="btn btn-primary btn-sm"><i class="fa fa-shopping-cart"></i> Manage Orders</a></p>
                            <p><a href="/admin/products" class="btn btn-success btn-sm"><i class="fa fa-plus"></i> Add Product</a></p>
                            <p><a href="/admin/categories" class="btn btn-info btn-sm"><i class="fa fa-tags"></i> Manage Categories</a></p>
                            <p><a href="/admin/users" class="btn btn-warning btn-sm"><i class="fa fa-users"></i> Manage Users</a></p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="widget">
                    <div class="widget-head">
                        <div class="pull-left">Order Status Overview</div>
                        <div class="clearfix"></div>
                    </div>
                    <div class="widget-content">
                        <div class="padd">
                            <table class="table table-striped table-bordered table-hover">
                                <thead>
                                    <tr>
                                        <th>Status</th>
                                        <th>Count</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td><span class="label label-warning">Pending</span></td>
                                        <td>—</td>
                                        <td><a href="/admin/orders/pending" class="btn btn-xs btn-default">View</a></td>
                                    </tr>
                                    <tr>
                                        <td><span class="label label-info">Confirmed</span></td>
                                        <td>—</td>
                                        <td><a href="/admin/orders" class="btn btn-xs btn-default">View</a></td>
                                    </tr>
                                    <tr>
                                        <td><span class="label label-success">Completed</span></td>
                                        <td>—</td>
                                        <td><a href="/admin/orders" class="btn btn-xs btn-default">View</a></td>
                                    </tr>
                                    <tr>
                                        <td><span class="label label-danger">Cancelled</span></td>
                                        <td>—</td>
                                        <td><a href="/admin/orders" class="btn btn-xs btn-default">View</a></td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

        </div>
        <!-- Quick Actions Row End -->

    </div>
</div>
