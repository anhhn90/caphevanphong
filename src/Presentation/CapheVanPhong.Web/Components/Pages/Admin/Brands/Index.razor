@page "/admin/brands"
@layout AdminLayout
@attribute [Authorize(Roles = "Admin, SuperAdmin")]
@using CapheVanPhong.Application.Services
@using CapheVanPhong.Web.Components.Layout
@using Microsoft.AspNetCore.Authorization

@inject IBrandService BrandService
@inject NavigationManager NavigationManager

<PageTitle>Thương Hiệu - Cà Phê Văn Phòng Admin</PageTitle>

<div class="page-head">
    <h2 class="pull-left"><i class="fa fa-trademark"></i> Thương Hiệu</h2>
    <div class="bread-crumb pull-right">
        <a href="/admin"><i class="fa fa-home"></i> Home</a>
        <span class="divider">/</span>
        <a href="#" class="bread-current">Thương Hiệu</a>
    </div>
    <div class="clearfix"></div>
</div>

<form id="delete-form" method="post" @formname="delete-brand" style="display:none;">
    <AntiforgeryToken />
    <input type="hidden" name="DeleteBrandId" id="delete-brand-id" value="" />
</form>

<div class="matter">
    <div class="container">

        @if (!string.IsNullOrEmpty(_successMessage))
        {
            <div class="alert alert-success alert-dismissable">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                <i class="fa fa-check-circle"></i> @_successMessage
            </div>
        }
        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="alert alert-danger alert-dismissable">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                <i class="fa fa-exclamation-circle"></i> @_errorMessage
            </div>
        }

        <div class="row">
            <div class="col-md-12">
                <div class="widget">
                    <div class="widget-head">
                        <div class="pull-left">Tất Cả Thương Hiệu</div>
                        <div class="pull-right">
                            <a href="/admin/brands/create" class="btn btn-success btn-sm">
                                <i class="fa fa-plus"></i> Thêm Thương Hiệu
                            </a>
                        </div>
                        <div class="clearfix"></div>
                    </div>
                    <div class="widget-content">
                        <div class="padd">
                            <table class="table table-striped table-bordered table-hover">
                                <thead>
                                    <tr>
                                        <th>#</th>
                                        <th>Tên</th>
                                        <th>Slug</th>
                                        <th>Thứ Tự</th>
                                        <th>Trạng Thái</th>
                                        <th style="width:130px;">Thao Tác</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{int index = 1;}
                                    @foreach (var b in _brands)
                                    {
                                        <tr>
                                            <td>@index</td>
                                            <td><strong>@b.Name</strong></td>
                                            <td><code>@b.Slug</code></td>
                                            <td>@b.DisplayOrder</td>
                                            <td>
                                                @if (b.IsActive)
                                                { <span class="label label-success">Hiện</span> }
                                                else
                                                { <span class="label label-default">Ẩn</span> }
                                            </td>
                                            <td>
                                                <a href="/admin/brands/edit/@b.Id" class="btn btn-xs btn-primary">
                                                    <i class="fa fa-pencil"></i> Sửa
                                                </a>
                                                <button type="button" class="btn btn-xs btn-danger"
                                                        onclick="promptDelete(@b.Id, '@b.Name')">
                                                    <i class="fa fa-trash"></i> Xóa
                                                </button>
                                            </td>
                                        </tr>
                                        index++;
                                    }
                                    @if (_brands.Count == 0)
                                    {
                                        <tr><td colspan="6" class="text-center text-muted">Chưa có thương hiệu nào.</td></tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteModal" tabindex="-1" role="dialog">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal">&times;</button>
                <h4 class="modal-title"><i class="fa fa-exclamation-triangle text-danger"></i> Xác Nhận Xóa</h4>
            </div>
            <div class="modal-body">
                <p>Bạn có chắc muốn xóa thương hiệu <strong id="modal-name"></strong>?</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-default" data-dismiss="modal"><i class="fa fa-times"></i> Hủy</button>
                <button type="button" class="btn btn-danger" id="modal-confirm-btn"><i class="fa fa-trash"></i> Xóa</button>
            </div>
        </div>
    </div>
</div>

<script>
    function promptDelete(id, name) {
        document.getElementById('delete-brand-id').value = id;
        document.getElementById('modal-name').textContent = name;
        $('#deleteModal').modal('show');
    }
    document.getElementById('modal-confirm-btn').addEventListener('click', function () {
        $('#deleteModal').modal('hide');
        document.getElementById('delete-form').submit();
    });
</script>

@code {
    [SupplyParameterFromForm(FormName = "delete-brand")]
    private int? DeleteBrandId { get; set; }

    [SupplyParameterFromQuery(Name = "created")] private string? Created { get; set; }
    [SupplyParameterFromQuery(Name = "updated")] private string? Updated { get; set; }
    [SupplyParameterFromQuery(Name = "deleted")] private string? Deleted { get; set; }

    private List<CapheVanPhong.Domain.Entities.Brand> _brands = [];
    private string? _successMessage;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        if (DeleteBrandId.HasValue)
        {
            var (success, error) = await BrandService.DeleteAsync(DeleteBrandId.Value);
            if (success)
                NavigationManager.NavigateTo("/admin/brands?deleted=1", forceLoad: true);
            else
                _errorMessage = error;
        }

        if (Created == "1") _successMessage = "Thương hiệu đã được tạo thành công.";
        if (Updated == "1") _successMessage = "Thương hiệu đã được cập nhật thành công.";
        if (Deleted == "1") _successMessage = "Thương hiệu đã được xóa thành công.";

        var all = await BrandService.GetAllAsync();
        _brands = all.OrderBy(b => b.DisplayOrder).ThenBy(b => b.Name).ToList();
    }
}
