@page "/admin/brands/create"
@layout AdminLayout
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Admin, SuperAdmin")]
@using CapheVanPhong.Application.Helpers
@using CapheVanPhong.Application.Services
@using CapheVanPhong.Web.Components.Layout
@using Microsoft.AspNetCore.Authorization

@inject IBrandService BrandService
@inject NavigationManager NavigationManager

<PageTitle>Thêm Thương Hiệu - Cà Phê Văn Phòng Admin</PageTitle>

<div class="page-head">
    <h2 class="pull-left"><i class="fa fa-plus"></i> Thêm Thương Hiệu</h2>
    <div class="bread-crumb pull-right">
        <a href="/admin"><i class="fa fa-home"></i> Home</a>
        <span class="divider">/</span>
        <a href="/admin/brands">Thương Hiệu</a>
        <span class="divider">/</span>
        <a href="#" class="bread-current">Thêm Mới</a>
    </div>
    <div class="clearfix"></div>
</div>

<div class="matter">
    <div class="container">
        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="alert alert-danger alert-dismissable">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @_errorMessage
            </div>
        }
        <div class="row">
            <div class="col-md-8">
                <div class="widget">
                    <div class="widget-head">
                        <div class="pull-left">Thông Tin Thương Hiệu</div>
                        <div class="clearfix"></div>
                    </div>
                    <div class="widget-content">
                        <div class="padd">
                            <form @onsubmit="HandleSubmitAsync" @onsubmit:preventDefault>
                                <div class="form-group">
                                    <label>Tên <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control"
                                           value="@_name" @oninput="OnNameInput"
                                           placeholder="VD: Wega" />
                                </div>
                                <div class="form-group">
                                    <label>Slug <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control" @bind="_slug" placeholder="VD: wega" />
                                    <p class="help-block">Tự động tạo từ tên.</p>
                                </div>
                                <div class="form-group">
                                    <label>Mô Tả</label>
                                    <textarea class="form-control" rows="2" @bind="_description"></textarea>
                                </div>
                                <div class="form-group">
                                    <label>Tên File Logo</label>
                                    <input type="text" class="form-control" @bind="_logoName" placeholder="VD: logo.png" />
                                    <p class="help-block">Đặt file vào thư mục <code>wwwroot/public/img/brands/</code>.</p>
                                </div>
                                <div class="form-group">
                                    <label>Thứ Tự Hiển Thị</label>
                                    <input type="number" class="form-control" @bind="_displayOrder" min="0" />
                                </div>
                                <div class="form-group">
                                    <a href="/admin/brands" class="btn btn-default"><i class="fa fa-arrow-left"></i> Quay Lại</a>
                                    <button type="submit" class="btn btn-primary" disabled="@_isSubmitting">
                                        <i class="fa fa-save"></i> Lưu
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private string _name = string.Empty;
    private string _slug = string.Empty;
    private string? _description;
    private string? _logoName;
    private int _displayOrder;
    private bool _isSubmitting;
    private string? _errorMessage;

    private void OnNameInput(ChangeEventArgs e)
    {
        _name = e.Value?.ToString() ?? string.Empty;
        _slug = SlugHelper.Generate(_name);
    }

    private async Task HandleSubmitAsync()
    {
        _isSubmitting = true;
        _errorMessage = null;
        if (string.IsNullOrWhiteSpace(_name)) { _errorMessage = "Tên không được để trống."; _isSubmitting = false; return; }
        if (string.IsNullOrWhiteSpace(_slug)) _slug = SlugHelper.Generate(_name);

        var (success, error) = await BrandService.CreateAsync(_name, _slug,
            string.IsNullOrWhiteSpace(_description) ? null : _description,
            string.IsNullOrWhiteSpace(_logoName) ? null : _logoName, _displayOrder);

        if (success) NavigationManager.NavigateTo("/admin/brands?created=1", forceLoad: true);
        else { _errorMessage = error; _isSubmitting = false; }
    }
}
