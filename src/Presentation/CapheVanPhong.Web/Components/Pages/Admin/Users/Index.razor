@page "/admin/users"
@layout AdminLayout
@attribute [Authorize(Roles = "Admin, SuperAdmin")]
@using CapheVanPhong.Web.Components.Layout
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity

@inject UserManager<IdentityUser> UserManager
@inject NavigationManager NavigationManager

<PageTitle>Users - Cà Phê Văn Phòng Admin</PageTitle>

<!-- Page Heading -->
<div class="page-head">
    <h2 class="pull-left"><i class="fa fa-users"></i> Users</h2>
    <div class="bread-crumb pull-right">
        <a href="/admin"><i class="fa fa-home"></i> Home</a>
        <span class="divider">/</span>
        <a href="#" class="bread-current">Users</a>
    </div>
    <div class="clearfix"></div>
</div>

<!-- Single delete form (outside the loop — Blazor SSR requires unique @formname) -->
<form id="delete-form" method="post" @formname="delete-user" style="display:none;">
    <AntiforgeryToken />
    <input type="hidden" name="DeleteUserId" id="delete-user-id" value="" />
</form>

<!-- Matter -->
<div class="matter">
    <div class="container">

        @if (!string.IsNullOrEmpty(_successMessage))
        {
            <div class="alert alert-success alert-dismissable">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                <i class="fa fa-check-circle"></i> @_successMessage
            </div>
        }
        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="alert alert-danger alert-dismissable">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                <i class="fa fa-exclamation-circle"></i> @_errorMessage
            </div>
        }

        <div class="row">
            <div class="col-md-12">
                <div class="widget">
                    <div class="widget-head">
                        <div class="pull-left">All Users</div>
                        <div class="pull-right">
                            <a href="/admin/users/create" class="btn btn-success btn-sm">
                                <i class="fa fa-plus"></i> Create User
                            </a>
                        </div>
                        <div class="clearfix"></div>
                    </div>
                    <div class="widget-content">
                        <div class="padd">
                            <table class="table table-striped table-bordered table-hover">
                                <thead>
                                    <tr>
                                        <th>#</th>
                                        <th>Username</th>
                                        <th>Email</th>
                                        <th>Roles</th>
                                        <th style="width:160px;">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{int index = 1;}
                                    @foreach (var item in _users)
                                    {
                                        <tr>
                                            <td>@index</td>
                                            <td>@item.UserName</td>
                                            <td>@item.Email</td>
                                            <td>
                                                @foreach (var role in item.Roles)
                                                {
                                                    <span class="label @GetRoleLabelClass(role)">@role</span>
                                                    <text> </text>
                                                }
                                            </td>
                                            <td>
                                                @{bool targetIsSuperAdmin = item.Roles.Contains("SuperAdmin", StringComparer.OrdinalIgnoreCase);}
                                                @if (_currentUserIsSuperAdmin || !targetIsSuperAdmin)
                                                {
                                                    <a href="/admin/users/edit/@item.Id" class="btn btn-xs btn-primary">
                                                        <i class="fa fa-pencil"></i> Edit
                                                    </a>
                                                }
                                                @if (item.Id != _currentUserId && (_currentUserIsSuperAdmin || !targetIsSuperAdmin))
                                                {
                                                    <button type="button" class="btn btn-xs btn-danger"
                                                            onclick="promptDelete('@item.Id', '@item.UserName')">
                                                        <i class="fa fa-trash"></i> Delete
                                                    </button>
                                                }
                                            </td>
                                        </tr>
                                        index++;
                                    }
                                    @if (_users.Count == 0)
                                    {
                                        <tr><td colspan="5" class="text-center text-muted">No users found.</td></tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

<!-- Delete confirmation modal (Bootstrap 3) -->
<div class="modal fade" id="deleteModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal">&times;</button>
                <h4 class="modal-title"><i class="fa fa-exclamation-triangle text-danger"></i> Confirm Delete</h4>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete user <strong id="modal-username"></strong>?</p>
                <p class="text-muted small">This action cannot be undone.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-default" data-dismiss="modal">
                    <i class="fa fa-times"></i> Cancel
                </button>
                <button type="button" class="btn btn-danger" id="modal-confirm-btn">
                    <i class="fa fa-trash"></i> Delete
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    function promptDelete(userId, username) {
        document.getElementById('delete-user-id').value = userId;
        document.getElementById('modal-username').textContent = username;
        $('#deleteModal').modal('show');
    }

    document.getElementById('modal-confirm-btn').addEventListener('click', function () {
        $('#deleteModal').modal('hide');
        document.getElementById('delete-form').submit();
    });
</script>

@code {
    [SupplyParameterFromForm(FormName = "delete-user")]
    private string? DeleteUserId { get; set; }

    [SupplyParameterFromQuery(Name = "created")]
    private string? Created { get; set; }

    [SupplyParameterFromQuery(Name = "updated")]
    private string? Updated { get; set; }

    [SupplyParameterFromQuery(Name = "deleted")]
    private string? Deleted { get; set; }

    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private List<UserViewModel> _users = [];
    private string? _currentUserId;
    private bool _currentUserIsSuperAdmin;
    private string? _successMessage;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        // Resolve current user identity first — needed by HandleDeleteAsync guards
        _currentUserId = HttpContext?.User.FindFirst(
            System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        _currentUserIsSuperAdmin = HttpContext?.User.IsInRole("SuperAdmin") ?? false;

        if (!string.IsNullOrEmpty(DeleteUserId))
        {
            await HandleDeleteAsync();
            return; // on success NavigateTo redirects; on error falls through to render
        }

        if (Created == "1") _successMessage = "User created successfully.";
        if (Updated == "1") _successMessage = "User updated successfully.";
        if (Deleted == "1") _successMessage = "User deleted successfully.";

        await LoadUsersAsync();
    }

    private async Task HandleDeleteAsync()
    {
        var user = await UserManager.FindByIdAsync(DeleteUserId!);
        if (user is null)
        {
            _errorMessage = "User not found.";
            await LoadUsersAsync();
            return;
        }

        if (user.Id == _currentUserId)
        {
            _errorMessage = "You cannot delete your own account.";
            await LoadUsersAsync();
            return;
        }

        if (await UserManager.IsInRoleAsync(user, "SuperAdmin") && !_currentUserIsSuperAdmin)
        {
            _errorMessage = "Only SuperAdmin can delete a SuperAdmin account.";
            await LoadUsersAsync();
            return;
        }

        var result = await UserManager.DeleteAsync(user);
        if (result.Succeeded)
            NavigationManager.NavigateTo("/admin/users?deleted=1", forceLoad: true);
        else
        {
            _errorMessage = string.Join(" ", result.Errors.Select(e => e.Description));
            await LoadUsersAsync();
        }
    }

    private async Task LoadUsersAsync()
    {
        var allUsers = UserManager.Users.ToList();
        _users = [];

        foreach (var u in allUsers)
        {
            var roles = await UserManager.GetRolesAsync(u);
            _users.Add(new UserViewModel
            {
                Id = u.Id,
                UserName = u.UserName ?? "",
                Email = u.Email ?? "",
                Roles = roles.ToList()
            });
        }

        _users = _users.OrderBy(u => u.UserName).ToList();
    }

    private static string GetRoleLabelClass(string role) => role.ToLower() switch
    {
        "superadmin" => "label-danger",
        "admin"      => "label-warning",
        _            => "label-info"
    };

    private sealed class UserViewModel
    {
        public string Id { get; set; } = "";
        public string UserName { get; set; } = "";
        public string Email { get; set; } = "";
        public List<string> Roles { get; set; } = [];
    }
}
