@page "/admin/categories"
@layout AdminLayout
@attribute [Authorize(Roles = "Admin, SuperAdmin")]
@using CapheVanPhong.Application.Services
@using CapheVanPhong.Web.Components.Layout
@using Microsoft.AspNetCore.Authorization

@inject ICategoryService CategoryService
@inject NavigationManager NavigationManager

<PageTitle>Categories - Cà Phê Văn Phòng Admin</PageTitle>

<!-- Page Heading -->
<div class="page-head">
    <h2 class="pull-left"><i class="fa fa-sitemap"></i> Danh Mục</h2>
    <div class="bread-crumb pull-right">
        <a href="/admin"><i class="fa fa-home"></i> Home</a>
        <span class="divider">/</span>
        <a href="#" class="bread-current">Danh Mục</a>
    </div>
    <div class="clearfix"></div>
</div>

<!-- Delete form -->
<form id="delete-form" method="post" @formname="delete-category" style="display:none;">
    <AntiforgeryToken />
    <input type="hidden" name="DeleteCategoryId" id="delete-category-id" value="" />
</form>

<!-- Matter -->
<div class="matter">
    <div class="container">

        @if (!string.IsNullOrEmpty(_successMessage))
        {
            <div class="alert alert-success alert-dismissable">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                <i class="fa fa-check-circle"></i> @_successMessage
            </div>
        }
        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="alert alert-danger alert-dismissable">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                <i class="fa fa-exclamation-circle"></i> @_errorMessage
            </div>
        }

        <div class="row">
            <div class="col-md-12">
                <div class="widget">
                    <div class="widget-head">
                        <div class="pull-left">Tất Cả Danh Mục</div>
                        <div class="pull-right">
                            <a href="/admin/categories/create" class="btn btn-success btn-sm">
                                <i class="fa fa-plus"></i> Thêm Danh Mục Gốc
                            </a>
                        </div>
                        <div class="clearfix"></div>
                    </div>
                    <div class="widget-content">
                        <div class="padd">
                            <table class="table table-striped table-bordered table-hover">
                                <thead>
                                    <tr>
                                        <th>#</th>
                                        <th>Tên</th>
                                        <th>Slug</th>
                                        <th>Thứ Tự</th>
                                        <th>Trạng Thái</th>
                                        <th style="width:220px;">Thao Tác</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{int index = 1;}
                                    @foreach (var (cat, depth) in GetTreeOrder())
                                    {
                                        <tr>
                                            <td>@(depth == 0 ? index++.ToString() : "")</td>
                                            <td>
                                                <div style="padding-left:@(depth * 22)px;">
                                                    @if (depth > 0)
                                                    {
                                                        <i class="fa fa-angle-right text-muted" style="margin-right:4px;"></i>
                                                    }
                                                    <strong>@cat.Name</strong>
                                                    @if (cat.Level == 0)
                                                    {
                                                        <span class="label label-default" style="margin-left:5px;">Root</span>
                                                    }
                                                    else if (cat.Level == 1)
                                                    {
                                                        <span class="label label-info" style="margin-left:5px;">Sub</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="label label-primary" style="margin-left:5px;">Leaf</span>
                                                    }
                                                </div>
                                            </td>
                                            <td><code>@cat.Slug</code></td>
                                            <td>@cat.DisplayOrder</td>
                                            <td>
                                                @if (cat.IsActive)
                                                {
                                                    <span class="label label-success">Hiện</span>
                                                }
                                                else
                                                {
                                                    <span class="label label-default">Ẩn</span>
                                                }
                                            </td>
                                            <td>
                                                @if (cat.Level < 2)
                                                {
                                                    <a href="/admin/categories/create?parentId=@cat.Id" class="btn btn-xs btn-info" title="Thêm danh mục con">
                                                        <i class="fa fa-plus"></i> Child
                                                    </a>
                                                }
                                                <a href="/admin/categories/edit/@cat.Id" class="btn btn-xs btn-primary">
                                                    <i class="fa fa-pencil"></i> Sửa
                                                </a>
                                                <button type="button" class="btn btn-xs btn-danger"
                                                        onclick="promptDelete(@cat.Id, '@cat.Name.Replace("'", "\\'")')">
                                                    <i class="fa fa-trash"></i> Xóa
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                    @if (_allCategories.Count == 0)
                                    {
                                        <tr><td colspan="6" class="text-center text-muted">Chưa có danh mục nào.</td></tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

<!-- Delete confirmation modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal">&times;</button>
                <h4 class="modal-title"><i class="fa fa-exclamation-triangle text-danger"></i> Xác Nhận Xóa</h4>
            </div>
            <div class="modal-body">
                <p>Bạn có chắc muốn xóa danh mục <strong id="modal-name"></strong>?</p>
                <p class="text-muted small">Không thể xóa nếu danh mục còn danh mục con. Hành động này không thể hoàn tác.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-default" data-dismiss="modal">
                    <i class="fa fa-times"></i> Hủy
                </button>
                <button type="button" class="btn btn-danger" id="modal-confirm-btn">
                    <i class="fa fa-trash"></i> Xóa
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    function promptDelete(id, name) {
        document.getElementById('delete-category-id').value = id;
        document.getElementById('modal-name').textContent = name;
        $('#deleteModal').modal('show');
    }
    document.getElementById('modal-confirm-btn').addEventListener('click', function () {
        $('#deleteModal').modal('hide');
        document.getElementById('delete-form').submit();
    });
</script>

@code {
    [SupplyParameterFromForm(FormName = "delete-category")]
    private int? DeleteCategoryId { get; set; }

    [SupplyParameterFromQuery(Name = "created")]
    private string? Created { get; set; }

    [SupplyParameterFromQuery(Name = "updated")]
    private string? Updated { get; set; }

    [SupplyParameterFromQuery(Name = "deleted")]
    private string? Deleted { get; set; }

    private List<CapheVanPhong.Domain.Entities.Category> _allCategories = [];
    private string? _successMessage;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        if (DeleteCategoryId.HasValue)
        {
            var (success, error) = await CategoryService.DeleteAsync(DeleteCategoryId.Value);
            if (success)
                NavigationManager.NavigateTo("/admin/categories?deleted=1", forceLoad: true);
            else
                _errorMessage = error;
        }

        if (Created == "1") _successMessage = "Danh mục đã được tạo thành công.";
        if (Updated == "1") _successMessage = "Danh mục đã được cập nhật thành công.";
        if (Deleted == "1") _successMessage = "Danh mục đã được xóa thành công.";

        _allCategories = (await CategoryService.GetAllAsync()).ToList();
    }

    private IEnumerable<(CapheVanPhong.Domain.Entities.Category cat, int depth)> GetTreeOrder()
    {
        var roots = _allCategories
            .Where(c => c.ParentId == null)
            .OrderBy(c => c.DisplayOrder).ThenBy(c => c.Name);

        foreach (var root in roots)
        {
            yield return (root, 0);
            var children = _allCategories
                .Where(c => c.ParentId == root.Id)
                .OrderBy(c => c.DisplayOrder).ThenBy(c => c.Name);
            foreach (var child in children)
            {
                yield return (child, 1);
                var grandchildren = _allCategories
                    .Where(c => c.ParentId == child.Id)
                    .OrderBy(c => c.DisplayOrder).ThenBy(c => c.Name);
                foreach (var gc in grandchildren)
                    yield return (gc, 2);
            }
        }
    }
}
