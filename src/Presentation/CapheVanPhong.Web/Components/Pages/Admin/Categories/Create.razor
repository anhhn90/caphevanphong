@page "/admin/categories/create"
@layout AdminLayout
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Admin, SuperAdmin")]
@using CapheVanPhong.Application.Helpers
@using CapheVanPhong.Application.Services
@using CapheVanPhong.Web.Components.Layout
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.WebUtilities

@inject ICategoryService CategoryService
@inject IFileStorageService FileStorageService
@inject NavigationManager NavigationManager

<PageTitle>Thêm Danh Mục - Cà Phê Văn Phòng Admin</PageTitle>

<!-- Page Heading -->
<div class="page-head">
    <h2 class="pull-left"><i class="fa fa-plus"></i> Thêm Danh Mục</h2>
    <div class="bread-crumb pull-right">
        <a href="/admin"><i class="fa fa-home"></i> Home</a>
        <span class="divider">/</span>
        <a href="/admin/categories">Danh Mục</a>
        <span class="divider">/</span>
        <a href="#" class="bread-current">Thêm Mới</a>
    </div>
    <div class="clearfix"></div>
</div>

<!-- Matter -->
<div class="matter">
    <div class="container">

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="alert alert-danger alert-dismissable">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                <i class="fa fa-exclamation-circle"></i> @_errorMessage
            </div>
        }

        <div class="row">
            <div class="col-md-8">
                <div class="widget">
                    <div class="widget-head">
                        <div class="pull-left">Thông Tin Danh Mục</div>
                        <div class="clearfix"></div>
                    </div>
                    <div class="widget-content">
                        <div class="padd">
                            <form @onsubmit="HandleSubmitAsync" @onsubmit:preventDefault>

                                <div class="form-group">
                                    <label>Danh Mục Cha</label>
                                    <select class="form-control" @bind="_parentId">
                                        <option value="">-- Không có (Danh mục gốc) --</option>
                                        @foreach (var c in _parentCandidates)
                                        {
                                            var prefix = c.Level == 0 ? "" : "\u00a0\u00a0\u00a0\u00a0";
                                            <option value="@c.Id">@(prefix + c.Name)</option>
                                        }
                                    </select>
                                    <p class="help-block">Chọn danh mục cha nếu đây là danh mục con. Tối đa 3 cấp.</p>
                                </div>

                                <div class="form-group">
                                    <label>Tên Danh Mục <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control"
                                           value="@_name" @oninput="OnNameInput"
                                           placeholder="VD: Máy Pha Cà Phê" />
                                </div>

                                <div class="form-group">
                                    <label>Slug <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control" @bind="_slug"
                                           placeholder="VD: may-pha-ca-phe" />
                                    <p class="help-block">URL thân thiện SEO. Tự động tạo từ tên.</p>
                                </div>

                                <div class="form-group">
                                    <label>Mô Tả</label>
                                    <textarea class="form-control" rows="3" @bind="_description"
                                              placeholder="Mô tả ngắn về danh mục..."></textarea>
                                </div>

                                <div class="form-group">
                                    <label>Hình Ảnh</label>
                                    <InputFile OnChange="OnImageSelected" accept="image/*" class="form-control" />
                                    @if (!string.IsNullOrEmpty(_imageName))
                                    {
                                        <p class="help-block"><i class="fa fa-check text-success"></i> Đã chọn: <strong>@_imageName</strong></p>
                                    }
                                    <p class="help-block">File sẽ được lưu vào <code>wwwroot/public/img/categories/</code>.</p>
                                </div>

                                <div class="form-group">
                                    <label>Thứ Tự Hiển Thị</label>
                                    <input type="number" class="form-control" @bind="_displayOrder" min="0" />
                                    <p class="help-block">Số nhỏ hơn hiển thị trước.</p>
                                </div>

                                <div class="form-group">
                                    <a href="/admin/categories" class="btn btn-default">
                                        <i class="fa fa-arrow-left"></i> Quay Lại
                                    </a>
                                    <button type="submit" class="btn btn-primary" disabled="@_isSubmitting">
                                        @if (_isSubmitting)
                                        {
                                            <i class="fa fa-spinner fa-spin"></i>
                                        }
                                        else
                                        {
                                            <i class="fa fa-save"></i>
                                        }
                                        Lưu Danh Mục
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

@code {
    private List<CapheVanPhong.Domain.Entities.Category> _parentCandidates = [];

    private int? _parentId;
    private string _name = string.Empty;
    private string _slug = string.Empty;
    private string _description = string.Empty;
    private string? _imageName;
    private IBrowserFile? _selectedFile;
    private int _displayOrder = 0;
    private bool _isSubmitting;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        // Pre-select parent if parentId is in query string
        var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
        if (QueryHelpers.ParseQuery(uri.Query).TryGetValue("parentId", out var parentIdStr)
            && int.TryParse(parentIdStr, out var pid))
        {
            _parentId = pid;
        }

        // Load categories that can be a parent (max depth 2, so parents must be Level 0 or 1)
        _parentCandidates = (await CategoryService.GetAllAsync())
            .Where(c => c.Level < 2)
            .OrderBy(c => c.Level)
            .ThenBy(c => c.DisplayOrder)
            .ThenBy(c => c.Name)
            .ToList();
    }

    private void OnNameInput(ChangeEventArgs e)
    {
        _name = e.Value?.ToString() ?? string.Empty;
        _slug = SlugHelper.Generate(_name);
    }

    private void OnImageSelected(InputFileChangeEventArgs e)
    {
        _selectedFile = e.File;
        _imageName = _selectedFile.Name;
    }

    private async Task HandleSubmitAsync()
    {
        _isSubmitting = true;
        _errorMessage = null;

        if (string.IsNullOrWhiteSpace(_name))
        {
            _errorMessage = "Tên danh mục không được để trống.";
            _isSubmitting = false;
            return;
        }

        if (string.IsNullOrWhiteSpace(_slug))
            _slug = SlugHelper.Generate(_name);

        if (_selectedFile is not null)
        {
            await using var stream = _selectedFile.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
            _imageName = await FileStorageService.SaveAsync("categories", _selectedFile.Name, stream);
        }

        var (success, error) = await CategoryService.CreateAsync(
            _name, _slug, _description, _parentId, _imageName, _displayOrder);

        if (success)
            NavigationManager.NavigateTo("/admin/categories?created=1", forceLoad: true);
        else
        {
            _errorMessage = error;
            _isSubmitting = false;
        }
    }
}
